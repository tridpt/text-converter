# Host interface to bind (use 0.0.0.0 to expose on the network / in Docker)
HOST=127.0.0.1

# Port the web server listens on
PORT=8000

# Maximum accepted upload size per request, in megabytes
MAX_UPLOAD_MB=25

# Use pandoc for high-fidelity conversions when available (0 to disable)
USE_PANDOC=1

# Optional API key. If set, /api/convert and /api/convert-url require the
# `X-API-Key` header. Leave empty to keep the API open.
API_KEY=

# Per-IP request cap per minute for conversion endpoints (0 = disabled)
RATE_LIMIT_PER_MINUTE=0
